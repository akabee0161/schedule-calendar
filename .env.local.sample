# AppSync 接続情報
# 初回 `cd infra && npx cdk deploy` 実行後に表示される Outputs の値をコピーする
#
#   AppSyncEndpoint  → VITE_APPSYNC_ENDPOINT
#   AppSyncApiKey    → VITE_APPSYNC_API_KEY
#
# セットアップ: cp .env.local.sample .env.local

VITE_APPSYNC_ENDPOINT=https://xxxxxxxxxxxxxxxxxxxxxxxxxx.appsync-api.ap-northeast-1.amazonaws.com/graphql
VITE_APPSYNC_API_KEY=da2-xxxxxxxxxxxxxxxxxxxxxxxxxx
